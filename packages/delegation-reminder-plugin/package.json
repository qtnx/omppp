{
	"type": "module",
	"name": "@oh-my-pi/delegation-reminder-plugin",
	"version": "1.3.2",
	"description": "Mid-turn delegation/orchestrator-mode enforcement extension for omp",
	"homepage": "https://omp.sh",
	"author": "Can Boluk",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/can1357/oh-my-pi.git",
		"directory": "packages/delegation-reminder-plugin"
	},
	"keywords": ["delegation", "extension", "orchestrator", "reminder", "subagent"],
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"test": "bun test --parallel",
		"lint": "biome lint .",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"devDependencies": {
		"@oh-my-pi/pi-coding-agent": "workspace:*",
		"@types/bun": "catalog:"
	},
	"peerDependencies": {
		"@oh-my-pi/pi-coding-agent": "^15"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"exports": {
		".": {
			"types": "./src/extension.ts",
			"import": "./src/extension.ts"
		},
		"./extension": {
			"types": "./src/extension.ts",
			"import": "./src/extension.ts"
		}
	},
	"omp": {
		"extensions": ["./src/extension.ts"]
	},
	"files": ["src", "CHANGELOG.md"]
}
